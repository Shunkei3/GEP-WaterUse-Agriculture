@article{Gleeson.etal2014,
  title = {A Glimpse beneath Earth's Surface: {{GLobal HYdrogeology MaPS}} ({{GLHYMPS}}) of Permeability and Porosity},
  shorttitle = {A Glimpse beneath Earth's Surface},
  author = {Gleeson, Tom and Moosdorf, Nils and Hartmann, Jens and {van Beek}, L. P. H.},
  year = 2014,
  journal = {Geophysical Research Letters},
  volume = {41},
  number = {11},
  pages = {3891--3898},
  issn = {1944-8007},
  doi = {10.1002/2014GL059856},
  urldate = {2025-06-02},
  abstract = {The lack of robust, spatially distributed subsurface data is the key obstacle limiting the implementation of complex and realistic groundwater dynamics into global land surface, hydrologic, and climate models. We map and analyze permeability and porosity globally and at high resolution for the first time. The new permeability and porosity maps are based on a recently completed high-resolution global lithology map that differentiates fine and coarse-grained sediments and sedimentary rocks, which is important since these have different permeabilities. The average polygon size in the new map is 100 km2, which is a more than hundredfold increase in resolution compared to the previous map which has an average polygon size of 14,000 km2. We also significantly improve the representation in regions of weathered tropical soils and permafrost. The spatially distributed mean global permeability 10-15 m2 with permafrost or 10-14 m2 without permafrost. The spatially distributed mean porosity of the globe is 14\%. The maps will enable further integration of groundwater dynamics into land surface, hydrologic, and climate models.},
  copyright = {\copyright 2014. American Geophysical Union. All Rights Reserved.},
  langid = {english},
  keywords = {groundwater,hydrology models,land surface models,permeability},
  file = {/Users/shunkeikakimoto/Zotero/storage/BD5F7UI8/Gleeson et al. - 2014 - A glimpse beneath earth's surface GLobal HYdrogeology MaPS (GLHYMPS) of permeability and porosity.pdf;/Users/shunkeikakimoto/Zotero/storage/7CF76H8C/2014GL059856.html}
}

@article{Glenn.etal2010,
  title = {Vegetation {{Index Methods}} for {{Estimating Evapotranspiration}} by {{Remote Sensing}}},
  author = {Glenn, Edward P. and Nagler, Pamela L. and Huete, Alfredo R.},
  year = 2010,
  month = dec,
  journal = {Surveys in Geophysics},
  volume = {31},
  number = {6},
  pages = {531--555},
  issn = {1573-0956},
  doi = {10.1007/s10712-010-9102-2},
  urldate = {2025-07-08},
  abstract = {Evapotranspiration (ET) is the largest term after precipitation in terrestrial water budgets. Accurate estimates of ET are needed for numerous agricultural and natural resource management tasks and to project changes in hydrological cycles due to potential climate change. We explore recent methods that combine vegetation indices (VI) from satellites with ground measurements of actual ET (ETa) and meteorological data to project ETa over a wide range of biome types and scales of measurement, from local to global estimates. The majority of these use time-series imagery from the Moderate Resolution Imaging Spectrometer on the Terra satellite to project ET over seasons and years. The review explores the theoretical basis for the methods, the types of ancillary data needed, and their accuracy and limitations. Coefficients of determination between modeled ETa and measured ETa are in the range of 0.45--0.95, and root mean square errors are in the range of 10--30\% of mean ETa values across biomes, similar to methods that use thermal infrared bands to estimate ETa and within the range of accuracy of the ground measurements by which they are calibrated or validated. The advent of frequent-return satellites such as Terra and planed replacement platforms, and the increasing number of moisture and carbon flux tower sites over the globe, have made these methods feasible. Examples of operational algorithms for ET in agricultural and natural ecosystems are presented. The goal of the review is to enable potential end-users from different disciplines to adapt these methods to new applications that require spatially-distributed ET estimates.},
  langid = {english},
  keywords = {Agroecology,Agronomy,Applied Ecology,Enhanced Vegetation Index,Ethnographic Methods,Fluxnet,Methodology of Data Collection and Processing,MODIS,NDVI,Remote sensing,Theory and Algorithms for Application Domains},
  file = {/Users/shunkeikakimoto/Zotero/storage/4YSXHQI8/Glenn et al. - 2010 - Vegetation Index Methods for Estimating Evapotranspiration by Remote Sensing.pdf}
}

