@article{Staal.etal2020,
  title = {Feedback between Drought and Deforestation in the {{Amazon}}},
  author = {Staal, Arie and Flores, Bernardo M and Aguiar, Ana Paula D and Bosmans, Joyce H C and Fetzer, Ingo and Tuinenburg, Obbe A},
  year = 2020,
  month = apr,
  journal = {Environmental Research Letters},
  volume = {15},
  number = {4},
  pages = {044024},
  issn = {1748-9326},
  doi = {10.1088/1748-9326/ab738e},
  urldate = {2024-05-16},
  abstract = {Abstract             Deforestation and drought are among the greatest environmental pressures on the Amazon rainforest, possibly destabilizing the forest-climate system. Deforestation in the Amazon reduces rainfall regionally, while this deforestation itself has been reported to be facilitated by droughts. Here we quantify the interactions between drought and deforestation spatially across the Amazon during the early 21st century. First, we relate observed fluctuations in deforestation rates to dry-season intensity; second, we determine the effect of conversion of forest to cropland on evapotranspiration; and third, we simulate the subsequent downwind reductions in rainfall due to decreased atmospheric water input. We find large variability in the response of deforestation to dry-season intensity, with a significant but small average increase in deforestation rates with a more intense dry season: with every mm of water deficit, deforestation tends to increase by 0.13\% per year. Deforestation, in turn, has caused an estimated 4\% of the recent observed drying, with the south-western part of the Amazon being most strongly affected. Combining both effects, we quantify a reinforcing drought-deforestation feedback that is currently small, but becomes gradually stronger with cumulative deforestation. Our results suggest that global climate change, not deforestation, is the main driver of recent drying in the Amazon. However, a feedback between drought and deforestation implies that increases in either of them will impede efforts to curb both.},
  langid = {english},
  file = {/Users/shunkeikakimoto/Zotero/storage/ATQKTEEL/Staal et al. - 2020 - Feedback between drought and deforestation in the .pdf}
}

@misc{Stamatiadou.etal2024,
  type = {{{SSRN Scholarly Paper}}},
  title = {Unveiling the {{Hidden Treasures}}: {{A Meta-Analysis}} and {{Map}} of the {{Monetary Value}} of {{Mediterranean Seagrass Ecosystem Services}}},
  shorttitle = {Unveiling the {{Hidden Treasures}}},
  author = {Stamatiadou, Valentini and Mazaris, Antonios and Katsanevakis, Stelios},
  year = 2024,
  month = apr,
  number = {4782372},
  eprint = {4782372},
  publisher = {Social Science Research Network},
  address = {Rochester, NY},
  doi = {10.2139/ssrn.4782372},
  urldate = {2025-03-31},
  abstract = {Seagrass meadows in the Mediterranean Sea provide a broad range of services contributing to the economy and human welfare, yet their value is often underestimated in policy decisions. This study screened 386 publications, with fourteen qualifying for statistical meta-analysis, providing 74 observations (predominantly in the northwestern Mediterranean) across eight ecosystem services (coastal protection, water purification, food provision, climate regulation, biotic materials and biofuels, life cycle maintenance, recreation and tourism, and cognitive effects). Employing a meta-regression model and standardizing values in International dollars (Int\$) per hectare per year (with 2020 as a reference year for valuation), this study quantified the economic value of seagrass ecosystem services. Key factors influencing seagrass values include GDP per capita, Marine Protected Area coverage, and ecosystem service type. The meta-analysis model extrapolated these values, estimating the annual worth of Mediterranean seagrass ecosystem services at approximately 6.7 billion Int\$/yr, with notable country-specific variations. Italy and Slovenia exemplified the highest and lowest valuations, respectively. The average per hectare value of seagrass ecosystem services was estimated at 5,015 Int\$/ha/yr. Monaco stood out, exhibiting the highest per hectare value of 336,676 Int\$/ha/yr for the eight ecosystem services assessed. This research underscores the utility of meta-analysis and benefit transfer in policy formulation, especially where direct valuation studies are absent, and advocates for intensified seagrass valuation research, particularly in underrepresented Mediterranean regions and services.},
  archiveprefix = {Social Science Research Network},
  langid = {english},
  keywords = {ecosystem services,Mediterranean,meta-analysis,monetary,seagrass,valuation}
}

