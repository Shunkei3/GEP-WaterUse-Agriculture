}

@article{Partridge.etal2018,
  title = {Spatially {{Distinct Seasonal Patterns}} and {{Forcings}} of the {{U}}.{{S}}. {{Warming Hole}}},
  author = {Partridge, T. F. and Winter, J. M. and Osterberg, E. C. and Hyndman, D. W. and Kendall, A. D. and Magilligan, F. J.},
  year = 2018,
  journal = {Geophysical Research Letters},
  volume = {45},
  number = {4},
  pages = {2055--2063},
  issn = {1944-8007},
  doi = {10.1002/2017GL076463},
  urldate = {2024-09-09},
  abstract = {We present a novel approach to characterize the spatiotemporal evolution of regional cooling across the eastern United States (commonly called the U.S. warming hole), by defining a spatially explicit boundary around the region of most persistent cooling. The warming hole emerges after a regime shift in 1958 where annual maximum (Tmax) and minimum (Tmin) temperatures decreased by 0.83{$^\circ$}C and 0.46{$^\circ$}C, respectively. The annual warming hole consists of two distinct seasonal modes, one located in the southeastern United States during winter and spring and the other in the midwestern United States during summer and autumn. A correlation analysis indicates that the seasonal modes differ in causation. Winter temperatures in the warming hole are significantly correlated with the Meridional Circulation Index, North Atlantic Oscillation, and Pacific Decadal Oscillation. However, the variability of ocean-atmosphere circulation modes is insufficient to explain the summer temperature patterns of the warming hole.},
  copyright = {\copyright 2018. American Geophysical Union. All Rights Reserved.},
  langid = {english},
  keywords = {anomalous cooling,climate variability,jet stream,regional climate,warming hole},
  file = {/Users/shunkeikakimoto/Zotero/storage/GEN825W9/Partridge et al. - 2018 - Spatially Distinct Seasonal Patterns and Forcings .pdf;/Users/shunkeikakimoto/Zotero/storage/XYCSIJAZ/2017GL076463.html}
}

@article{Partridge.etal2023,
