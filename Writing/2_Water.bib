  langid = {english},
  keywords = {,Agroecology,Climate-change impacts},
  file = {/Users/shunkeikakimoto/Zotero/storage/MSVDGILG/Partridge et al. - 2023 - Irrigation benefits outweigh costs in more US crop.pdf}
